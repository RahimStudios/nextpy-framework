{
  "name": "nextpy-psx",
  "displayName": "NextPy PSX",
  "description": "Complete NextPy PSX support with syntax highlighting, IntelliSense, and development tools",
  "version": "1.0.0",
  "publisher": "nextpy-framework",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "nextpy",
    "psx",
    "python",
    "jsx",
    "react",
    "web",
    "framework"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nextpy-psx",
        "aliases": [
          "NextPy PSX",
          "PSX",
          "nextpy"
        ],
        "extensions": [
          ".psx",
          ".py"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nextpy-psx",
        "scopeName": "source.nextpy.psx",
        "path": "./syntaxes/nextpy-psx.tmLanguage.json",
        "embeddedLanguages": [
          {
            "language": "python",
            "scopeName": "source.python.embedded.psx",
            "path": "./syntaxes/python-embedded.json"
          }
        ]
      }
    ],
    "snippets": [
      {
        "language": "nextpy-psx",
        "path": "./snippets/nextpy-psx.json"
      }
    ],
    "configuration": [
      {
        "title": "NextPy PSX",
        "properties": {
          "nextpyPsx.enableSyntaxHighlighting": {
            "type": "boolean",
            "default": true,
            "description": "Enable PSX syntax highlighting"
          },
          "nextpyPsx.enableIntelliSense": {
            "type": "boolean",
            "default": true,
            "description": "Enable PSX IntelliSense and auto-completion"
          },
          "nextpyPsx.enableFormatting": {
            "type": "boolean",
            "default": true,
            "description": "Enable PSX code formatting"
          },
          "nextpyPsx.pythonLogicHighlighting": {
            "type": "boolean",
            "default": true,
            "description": "Highlight Python logic blocks in PSX"
          },
          "nextpyPsx.componentSnippets": {
            "type": "boolean",
            "default": true,
            "description": "Enable PSX component snippets"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "nextpy-psx.createComponent",
        "title": "Create PSX Component",
        "category": "NextPy PSX"
      },
      {
        "command": "nextpy-psx.createPage",
        "title": "Create PSX Page",
        "category": "NextPy PSX"
      },
      {
        "command": "nextpy-psx.togglePythonLogic",
        "title": "Toggle Python Logic Highlighting",
        "category": "NextPy PSX"
      },
      {
        "command": "nextpy-psx.showDocumentation",
        "title": "Show PSX Documentation",
        "category": "NextPy PSX"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == .py || resourceExtname == .psx",
          "command": "nextpy-psx.createComponent",
          "group": "1_modification"
        },
        {
          "when": "resourceExtname == .py || resourceExtname == .psx",
          "command": "nextpy-psx.createPage",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "when": "resourceExtname == .py || resourceExtname == .psx",
          "command": "nextpy-psx.togglePythonLogic",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nextpy-psx.togglePythonLogic",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "editorTextFocus && resourceExtname =~ /\\.(py|psx)$/"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:nextpy-psx",
    "onCommand:nextpy-psx.createComponent",
    "onCommand:nextpy-psx.createPage"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nextpy-framework/vscode-nextpy-psx"
  },
  "bugs": {
    "url": "https://github.com/nextpy-framework/vscode-nextpy-psx/issues"
  },
  "homepage": "https://github.com/nextpy-framework/vscode-nextpy-psx#readme",
  "license": "MIT"
}
