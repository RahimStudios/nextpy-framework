{
  "comments": {
    "lineComment": "//",
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["{", "}"],
    ["<", ">"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    {"open": "{", "close": "}"},
    {"open": "<", "close": ">"},
    {"open": "(", "close": ")"},
    {"open": "[", "close": "]"},
    {"open": "\"", "close": "\""},
    {"open": "'", "close": "'"}
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["<", ">"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<!--\\s*#region\\b",
      "end": "^\\s*<!--\\s*#endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`\\~\\!\\@\\#\\$\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s\\w]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*<([a-zA-Z][a-zA-Z0-9-]*)(?!.*\\/\\s*>)(?!.*\\/\\s*>)",
    "decreaseIndentPattern": "^\\s*<\\/[a-zA-Z][a-zA-Z0-9-]*>",
    "unIndentedLinePattern": "^\\s*<\\!DOCTYPE.*>"
  }
}
