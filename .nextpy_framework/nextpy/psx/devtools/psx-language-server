#!/usr/bin/env python3
"""
PSX Language Server Launcher
Starts the PSX Language Server with proper configuration
"""

import sys
import os
import subprocess
from pathlib import Path

def find_language_server():
    """Find the PSX language server"""
    # Try to find it in the same directory
    current_dir = Path(__file__).parent
    server_path = current_dir / "language_server_lsp.py"
    
    if server_path.exists():
        return str(server_path)
    
    # Try to find it in the package
    try:
        import nextpy.psx.devtools.language_server_lsp as ls_module
        return ls_module.__file__
    except ImportError:
        pass
    
    return None

def main():
    """Main launcher"""
    server_path = find_language_server()
    
    if not server_path:
        print("Error: PSX Language Server not found")
        sys.exit(1)
    
    # Start the language server
    try:
        # Use python3 by default
        python_cmd = "python3"
        
        # Check if we're in a virtual environment
        if hasattr(sys, 'real_prefix') and sys.real_prefix:
            # Use the virtual environment's python
            python_cmd = sys.executable
        
        # Start the server
        cmd = [python_cmd, server_path] + sys.argv[1:]
        subprocess.run(cmd, check=True)
        
    except subprocess.CalledProcessError as e:
        print(f"Error starting PSX Language Server: {e}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("PSX Language Server stopped")
        sys.exit(0)

if __name__ == "__main__":
    main()
