{
  "comments": {
    "lineComment": "#",
    "blockComment": [ "/*", "*/" ]
  },
  "brackets": [
    ["<", ">"],
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    ["<", ">"],
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "surroundingPairs": [
    ["<", ">"],
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<!--\\s*#region\\b.*-->",
      "end": "^\\s*<!--\\s*#endregion\\b.*-->"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`\\~\\!\\@\\#\\%\\^&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\\\\\|\\;\\:\'\\",\\.\\<\\>/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "<([a-zA-Z][a-zA-Z0-9]*)(?!.*\\/>)|\\{[^}]*$",
    "decreaseIndentPattern": "^\\s*(</[a-zA-Z][a-zA-Z0-9]*>|\\})"
  }
}
