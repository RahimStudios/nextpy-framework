# Ignore generated and environment files within the vendored framework

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# build/dist directories
build/
dist/
*.egg-info/

# virtual envs
.venv/
env/

# Node
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/node_modules/

# IDEs & OS
.vscode/
.idea/
.DS_Store

# env files
.env
