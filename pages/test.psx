from nextpy.psx import useState, useEffect, interactive_component, create_onsubmit, create_onclick

@interactive_component
def Test(props=None):
    props={}

    [show, setShow] = useState(False)
    [name, setName] = useState("Rahim")
    handleToggle = create_onclick(lambda e: setShow(not show))
    handleNameChange = create_onclick(lambda e: setName("name changed to rahim"))
    
    return (
        <div>
            <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" create_onclick={handleToggle}>Toggle</button>
            <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" create_onclick={handleNameChange}>Change Name</button>
            {if show:
                <p>Visible</p>
            {else:
                <p>Hidden</p>
            }
            <p>{name}</p>
        </div>
    )
    
default = Test