  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "postcss-cli": "^11.0.1"
  }
}
